# ============================================================
# Attendify Server - Production .gitignore
# ============================================================

# ------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------
node_modules/
jspm_packages/
bower_components/
web_modules/

# ------------------------------------------------------------
# Environment variables and secrets
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------
# Runtime files
# ------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock

# ------------------------------------------------------------
# Diagnostic reports
# ------------------------------------------------------------
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ------------------------------------------------------------
# Coverage
# ------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# ------------------------------------------------------------
# Build outputs
# ------------------------------------------------------------
dist/
build/
out/
.output/
build/Release/

# ------------------------------------------------------------
# Cache directories
# ------------------------------------------------------------
.cache/
.parcel-cache/
.npm/
.eslintcache
.stylelintcache
.vite/
.temp/
.tmp/
tmp/

# ------------------------------------------------------------
# Framework generated directories
# ------------------------------------------------------------
.next/
.nuxt/
.svelte-kit/
.docusaurus/
.vuepress/dist/
**/.vitepress/dist/
**/.vitepress/cache/

# ------------------------------------------------------------
# Serverless / cloud tool caches
# ------------------------------------------------------------
.serverless/
.firebase/
.dynamodb/
.wrangler/

# ------------------------------------------------------------
# TypeScript / tooling
# ------------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------------
# Package manager files
# ------------------------------------------------------------
.yarn-integrity
.pnpm-store/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Editor / IDE files
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------
# REPL history
# ------------------------------------------------------------
.node_repl_history

# ------------------------------------------------------------
# Archives / packaged files
# ------------------------------------------------------------
*.tgz
*.zip
*.rar
*.7z

# ------------------------------------------------------------
# Local database / temporary files
# ------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# ------------------------------------------------------------
# Certificates / keys / secrets
# ------------------------------------------------------------
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx

# ------------------------------------------------------------
# Local backup files
# ------------------------------------------------------------
*.bak
*.backup
*.old
*.orig

# ------------------------------------------------------------
# Do not ignore documentation
# ------------------------------------------------------------
!docs/
!docs/**
!README.md

# ------------------------------------------------------------
# Do not ignore package lock
# ------------------------------------------------------------
!package-lock.json