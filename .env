###############################################################################
# 🔐 ENVIRONMENT CONFIGURATION FILE (.env)
###############################################################################
#
# 🎯 PURPOSE:
#
# This file defines the runtime configuration for the backend system.
# It contains environment-specific variables required for:
#
#   ✅ Database connectivity
#   ✅ Authentication (JWT)
#   ✅ Cryptographic integrity
#
# ------------------------------------------------------------
#
# 🧠 CONCEPTUAL MODEL:
#
# Modern backend systems externalize sensitive configuration:
#
#   Code (stateless logic)
#       +
#   Environment (runtime secrets/config)
#
# This design ensures:
#
#   ✅ Security (no secrets in source code)
#   ✅ Portability (same code, different environments)
#   ✅ Maintainability (centralized configuration management)
#
# ------------------------------------------------------------
#
# 🔐 SECURITY PRINCIPLE:
#
# NEVER commit this file to version control (GitHub)
#
# This file MUST be:
#
#   - locally stored
#   - injected into production environment (Railway / VPS)
#   - protected from exposure
#
###############################################################################



###############################################################################
# 🗄️ DATABASE CONFIGURATION
###############################################################################
#
# 🎯 PURPOSE:
# Defines connection to MongoDB Atlas cluster
#
# ------------------------------------------------------------
#
# 🧠 CONNECTION MODEL:
#
#   Backend Server
#         ↓
#   MongoDB Driver (Node.js)
#         ↓
#   TLS Encrypted Connection
#         ↓
#   MongoDB Atlas Cluster
#
# ------------------------------------------------------------
#
# 🔬 STRUCTURE:
#
# mongodb+srv://<username>:<password>@cluster-url/database
#
# ------------------------------------------------------------
#
# 🔐 SECURITY NOTES:
#
#   - Uses TLS encryption (mongodb+srv)
#   - Credentials MUST remain secret
#   - Avoid special characters or URL-encode them
#
###############################################################################


MONGO_URL=mongodb+srv://mahmoud_152069:mahmoud68939@cluster0.setvyms.mongodb.net/attendify?retryWrites=true&w=majority&appName=attendify


###############################################################################
# 🔐 JWT CONFIGURATION (AUTHENTICATION CORE)
###############################################################################
#
# 🎯 PURPOSE:
# Controls JSON Web Token generation and validation
#
# ------------------------------------------------------------
#
# 🧠 JWT MODEL:
#
#   Login → Generate Token → Client stores token
#        → Client sends token with every request
#        → Server verifies token (using secret)
#
# ------------------------------------------------------------
#
# 🔬 TOKEN STRUCTURE:
#
#   HEADER.PAYLOAD.SIGNATURE
#
# where:
#   - HEADER: algorithm metadata
#   - PAYLOAD: company identity
#   - SIGNATURE: HMAC using secret
#
# ------------------------------------------------------------
#
# 🔐 CRITICAL SECURITY COMPONENT:
#
# JWT_SECRET is used to sign tokens.
#
# If compromised:
#   ❌ attacker can forge tokens
#   ❌ full system compromise
#
###############################################################################

JWT_SECRET=9870c131ed32d521fe9df8a0303d267799b2d3344b925e3c8fea46007307d8fe



###############################################################################
# ⏱️ JWT EXPIRATION CONFIGURATION
###############################################################################
#
# 🎯 PURPOSE:
# Defines lifecycle of authentication tokens
#
# ------------------------------------------------------------
#
# 🧠 WHY EXPIRATION?
#
# Tokens should not live forever.
#
# This ensures:
#
#   ✅ Reduced attack window
#   ✅ Limits damage if token leaks
#
# ------------------------------------------------------------
#
# ✅ COMMON VALUES:
#
#   1h  → high security (short sessions)
#   1d  → balanced
#   7d  → convenience-focused
#
# ------------------------------------------------------------
#
# 🧠 FLOW:
#
#   Token Issued → Client uses → Token expires → must login again
#
###############################################################################

JWT_EXPIRES=7d



###############################################################################
# 🌐 OPTIONAL: SERVER CONFIGURATION
###############################################################################
#
# 🎯 Defines runtime behavior of server
#
# Optional but recommended for scalability
#
###############################################################################

PORT=3000

NODE_ENV=production



###############################################################################
# 🔐 ADVANCED SECURITY NOTES (ACADEMIC)
###############################################################################
#
# 🔬 THREAT MODEL:
#
# 1. Credential Leakage
#    → Mitigation: never expose .env
#
# 2. Token Forgery
#    → Mitigation: strong JWT_SECRET
#
# 3. MITM (Man-in-the-Middle)
#    → Mitigation: HTTPS (Cloudflare + Railway)
#
# 4. Database Breach
#    → Mitigation: password hashing (bcrypt)
#
# ------------------------------------------------------------
#
# 🧠 BEST PRACTICES:
#
# ✅ Use long random secrets
# ✅ Store secrets in environment variables only
# ✅ Rotate secrets periodically
# ✅ Use different .env for:
#    - development
#    - staging
#    - production
#
###############################################################################



###############################################################################
# 📊 SYSTEM CONFIGURATION FLOW
###############################################################################
#
# 🔁 FULL SYSTEM FLOW:
#
#   .env (THIS FILE)
#        ↓
#   Node.js process.env
#        ↓
#   Server Configuration
#        ↓
#   Routes / Middleware
#        ↓
#   Runtime Behavior
#
# ------------------------------------------------------------
#
# 🔁 AUTHENTICATION FLOW:
#
#   JWT_SECRET
#        ↓
#   Token Signing
#        ↓
#   Client receives token
#        ↓
#   Token sent in headers
#        ↓
#   Middleware verifies using JWT_SECRET
#
###############################################################################


###############################################################################
# 🏁 END OF FILE
###############################################################################