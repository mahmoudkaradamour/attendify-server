
###############################################################################
# 🔐 ENVIRONMENT CONFIGURATION FILE (.env)
###############################################################################
#
# 🎯 PURPOSE:
#
# This file defines runtime parameters for the backend system by
# externalizing configuration away from application logic.
#
# It provides:
#
#   ✅ Secret management (JWT, DB credentials)
#   ✅ Runtime behavior configuration
#   ✅ Environment-specific overrides
#
# ------------------------------------------------------------
#
# 🧠 CONFIGURATION MODEL:
#
# The backend follows the "Twelve-Factor App" principle:
#
#   Code (stateless)
#      +
#   Environment (configuration)
#
# ------------------------------------------------------------
#
# 📊 CONFIG FLOW DIAGRAM:
#
#   .env file (THIS FILE)
#         ↓
#   Node.js process.env loader (dotenv)
#         ↓
#   Application modules (routes, middleware)
#         ↓
#   Runtime behavior
#
# ------------------------------------------------------------
#
# 🔐 SECURITY PRINCIPLE:
#
#   ❌ NEVER commit this file to GitHub
#   ✅ ALWAYS store secrets outside the codebase
#   ✅ USE environment injection in production
#
###############################################################################



###############################################################################
# 🗄️ DATABASE CONFIGURATION (MONGODB ATLAS)
###############################################################################
#
# 🎯 PURPOSE:
#
# Defines connection string for MongoDB Atlas cluster.
#
# ------------------------------------------------------------
#
# 🧠 CONNECTION ARCHITECTURE:
#
#   Backend Server
#        ↓
#   MongoDB Driver (Node.js)
#        ↓
#   TLS/SSL Encrypted Channel
#        ↓
#   MongoDB Atlas Cluster
#
# ------------------------------------------------------------
#
# 🔬 URI STRUCTURE:
#
# mongodb+srv://<username>:<password>@cluster/database
#
# ------------------------------------------------------------
#
# 🔐 SECURITY NOTES:
#
#   ✅ Uses DNS-based SRV record (auto-scaling)
#   ✅ Encrypted via TLS
#   ✅ Credentials must be protected
#
# ------------------------------------------------------------
#
# ⚠️ IMPORTANT:
#
#   - URL-encode special characters in password
#   - DO NOT log this value
#
###############################################################################

MONGO_URL=mongodb+srv://mahmoud_152069:mahmoud68939@cluster0.setvyms.mongodb.net/attendify?retryWrites=true&w=majority&appName=attendify



###############################################################################
# 🔐 JWT CONFIGURATION (IDENTITY SYSTEM CORE)
###############################################################################
#
# 🎯 PURPOSE:
#
# Defines the cryptographic secret used for signing JWT tokens
#
# ------------------------------------------------------------
#
# 🧠 JWT SECURITY MODEL:
#
#   Login → jwt.sign(payload, secret)
#        ↓
#   Token issued to client
#        ↓
#   Client sends token
#        ↓
#   jwt.verify(token, same secret)
#
# ------------------------------------------------------------
#
# 🔬 TOKEN STRUCTURE:
#
#   HEADER.PAYLOAD.SIGNATURE
#
# SIGNATURE = HMAC_SHA256(secret)
#
# ------------------------------------------------------------
#
# 🚨 CRITICAL SECURITY WARNING:
#
# If JWT_SECRET is leaked:
#
#   ❌ Attackers can forge tokens
#   ❌ Full authentication bypass
#
###############################################################################

JWT_SECRET=9870c131ed32d521fe9df8a0303d267799b2d3344b925e3c8fea46007307d8fe




###############################################################################
# ⏱️ JWT EXPIRATION POLICY
###############################################################################
#
# 🎯 PURPOSE:
#
# Controls token lifetime (security vs usability tradeoff)
#
# ------------------------------------------------------------
#
# 🧠 FLOW:
#
#   Token issued
#        ↓
#   Used by client
#        ↓
#   Token expires (exp claim)
#        ↓
#   Client must re-authenticate
#
# ------------------------------------------------------------
#
# ✅ STRATEGY:
#
#   Short-lived token → high security
#   Long-lived token  → better UX
#
# ------------------------------------------------------------
#
# ✅ RECOMMENDED:
#
#   15m → high-security systems
#   1h  → financial/critical APIs
#   7d  → SaaS convenience systems
#
###############################################################################

JWT_EXPIRES=7d



###############################################################################
# 🔐 PASSWORD HASHING CONFIGURATION
###############################################################################
#
# 🎯 PURPOSE:
#
# Controls bcrypt computational cost
#
# ------------------------------------------------------------
#
# 🧠 CONCEPT:
#
# bcrypt cost factor controls time complexity:
#
#   cost = 2^rounds
#
# ------------------------------------------------------------
#
# ✅ RECOMMENDED VALUES:
#
#   10 → balanced (production default)
#   12 → high security
#   14 → very high (slow)
#
# ------------------------------------------------------------
#
###############################################################################

SALT_ROUNDS=10



###############################################################################
# 🌐 SERVER CONFIGURATION
###############################################################################
#
# 🎯 PURPOSE:
#
# Controls runtime behavior of Node.js server
#
# ------------------------------------------------------------
#
# PORT:
#   Network port binding
#
# NODE_ENV:
#   Defines runtime environment
#
#   development → debugging mode
#   production  → optimized mode
#
###############################################################################

PORT=3000
NODE_ENV=production



###############################################################################
# 🌍 OPTIONAL: SECURITY & NETWORK CONTROLS
###############################################################################
#
# These variables support advanced security features
# (used later in middleware / gateway)
#
###############################################################################

# ✅ Enable request logging (for debugging)
ENABLE_LOGGING=true

# ✅ Max failed login attempts before lock
MAX_LOGIN_ATTEMPTS=5

# ✅ Account lock duration (in minutes)
LOCK_DURATION=15

# ✅ Allowed countries (future geo filter)
ALLOWED_COUNTRIES=ALL



###############################################################################
# 📡 OPTIONAL: API & GATEWAY INTEGRATION
###############################################################################
#
# These variables prepare the system for scaling
#
###############################################################################

# ✅ External API base (microservice / integrations)
API_BASE_URL=https://attendify-worker.mahmouddamour-3aa.workers.dev

# ✅ Internal service authentication (future)
INTERNAL_API_KEY=f4252db7fd316e62c9a1dfa5f63f383278755f82e8e75e625f571f6369a8fe52



###############################################################################
# 📊 FULL SYSTEM FLOW (ACADEMIC MODEL)
###############################################################################
#
# 🔁 AUTHENTICATION FLOW:
#
#   JWT_SECRET
#        ↓
#   Token signing
#        ↓
#   Client receives token
#        ↓
#   Client sends Authorization header
#        ↓
#   Middleware verifies using JWT_SECRET
#
# ------------------------------------------------------------
#
# 🔁 DATABASE FLOW:
#
#   MONGO_URL
#        ↓
#   DB connection
#        ↓
#   Query execution
#        ↓
#   Data retrieval
#
# ------------------------------------------------------------
#
# 🔁 PASSWORD FLOW:
#
#   SALT_ROUNDS
#        ↓
#   bcrypt hashing
#        ↓
#   Store hash
#
###############################################################################



###############################################################################
# 🔐 ADVANCED SECURITY ANALYSIS
###############################################################################
#
# 🔬 THREAT MODEL:
#
# 1. Secret Exposure
#    → Mitigation: environment isolation
#
# 2. Token Forgery
#    → Mitigation: strong JWT_SECRET
#
# 3. Credential Leak
#    → Mitigation: hashing (bcrypt)
#
# 4. Replay Attacks
#    → Mitigation: JWT expiration
#
# ------------------------------------------------------------
#
# ✅ BEST PRACTICES:
#
#   - Rotate secrets periodically
#   - Use different secrets per environment
#   - Never expose .env
#   - Use secret managers in production
#
###############################################################################



